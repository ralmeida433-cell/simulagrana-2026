# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Pluggy API (Open Finance)
PLUGGY_CLIENT_ID=
PLUGGY_CLIENT_SECRET=

# Brapi API (Stock Data) - Get your free token at https://brapi.dev/
BRAPI_TOKEN=

# Financial Modeling Prep (FMP) - US Stock Data
FMP_API_KEY=

# Finnhub API - US Stock Context & News
FINNHUB_API_KEY=

# Twelve Data API - US Stock Charts
TWELVE_DATA_API_KEY=

# Gemini API Key - Get your free key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
API_KEY=
